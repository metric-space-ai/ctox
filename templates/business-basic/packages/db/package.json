{
  "name": "@ctox-business/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./accounting": "./src/accounting.ts",
    ".": "./src/index.ts",
    "./modules": "./src/modules.ts",
    "./operations": "./src/operations.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:accounting-smoke": "tsx scripts/accounting-smoke.ts",
    "generate": "drizzle-kit generate --config drizzle.config.ts",
    "migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
