DATABASE_URL="postgres://user:password@localhost:5432/ctox_business"
AUTH_SECRET="replace-with-random-secret"
CTOX_BRIDGE_URL="http://127.0.0.1:47118"
CTOX_BRIDGE_TOKEN=""
CTOX_BIN="ctox"
CTOX_ROOT="/path/to/ctox"
CTOX_BUSINESS_QUEUE_MODE="direct"
CTOX_BUSINESS_ENABLE_CTOX_EXECUTION="false"
CTOX_COMPETITIVE_MODEL="minimax-m2.7"
CTOX_OWN_PRODUCT_NAME="Own product"
CTOX_OWN_PRODUCT_URL="https://example.com"
CTOX_OWN_WEB_REPO="owner/web"
CTOX_OWN_PRODUCT_REPO="owner/product"

# Business OS access boundary:
# local = only the Business OS login, hybrid = Business OS login plus signed
# website sessions with the Business OS role, website = website sessions only.
CTOX_BUSINESS_OS_ACCESS_MODE="local"
CTOX_BUSINESS_USER="admin"
CTOX_BUSINESS_PASSWORD="ctox-business"
CTOX_WEBSITE_AUTH_SECRET=""
CTOX_WEBSITE_SESSION_COOKIE="ctox_website_session"
CTOX_BUSINESS_OS_ROLE="business_os_user"
CTOX_BUSINESS_OS_ADMIN_ROLE="business_os_admin"
