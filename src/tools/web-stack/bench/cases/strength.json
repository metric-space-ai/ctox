{
  "version": 1,
  "cases": [
    {
      "id": "strength.scrape.classify.portal_drift",
      "tier": "strength",
      "tool": "ctox_scrape",
      "families": ["CTOX-Strength"],
      "setup": [
        {
          "write_text": {
            "path": "${TMP_ROOT}/scripts/drift.sh",
            "content": "echo '{\"failure_mode\":\"portal_drift\"}'\n"
          }
        },
        {
          "write_json": {
            "path": "${TMP_ROOT}/seed/target-drift.json",
            "value": {
              "target_key": "strength-drift",
              "display_name": "Strength Drift",
              "start_url": "https://example.com",
              "config": { "skip_probe": true },
              "output_schema": { "schema_key": "v1", "record_key_fields": ["id"] }
            }
          }
        },
        {
          "command": ["scrape", "upsert-target", "--input", "${TMP_ROOT}/seed/target-drift.json", "--runtime-root", "${TMP_ROOT}/rt"],
          "assertions": [{ "path": "ok", "equals": true }]
        },
        {
          "command": ["scrape", "register-script", "--target-key", "strength-drift", "--script-file", "${TMP_ROOT}/scripts/drift.sh", "--language", "sh", "--runtime-root", "${TMP_ROOT}/rt"],
          "assertions": [{ "path": "ok", "equals": true }]
        }
      ],
      "command": ["scrape", "execute", "--target-key", "strength-drift", "--runtime-root", "${TMP_ROOT}/rt", "--timeout-seconds", "30"],
      "assertions": [
        { "path": "ok", "equals": true },
        { "path": "status", "equals": "portal_drift" },
        { "path": "should_queue_repair", "equals": true }
      ]
    },
