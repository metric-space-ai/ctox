    {
      "id": "strength.scrape.materialize.delta",
      "tier": "strength",
      "tool": "ctox_scrape",
      "families": ["CTOX-Strength"],
      "setup": [
        {
          "write_text": {
            "path": "${TMP_ROOT}/scripts/delta.sh",
            "content": "if printf '%s' \"$CTOX_SCRAPE_INPUT_JSON\" | grep -q '\"phase\":2'; then\n  echo '[{\"id\":\"A\",\"v\":\"2\"},{\"id\":\"C\",\"v\":\"1\"},{\"id\":\"D\",\"v\":\"1\"}]'\nelse\n  echo '[{\"id\":\"A\",\"v\":\"1\"},{\"id\":\"B\",\"v\":\"1\"},{\"id\":\"D\",\"v\":\"1\"}]'\nfi\n"
          }
        },
        {
          "write_json": {
            "path": "${TMP_ROOT}/seed/target-delta.json",
            "value": {
              "target_key": "strength-delta",
              "display_name": "Strength Delta",
              "start_url": "https://example.com",
              "config": { "skip_probe": true, "record_key_fields": ["id"] },
              "output_schema": { "schema_key": "v1", "record_key_fields": ["id"] }
            }
          }
        },
        {
          "command": ["scrape", "upsert-target", "--input", "${TMP_ROOT}/seed/target-delta.json", "--runtime-root", "${TMP_ROOT}/rt"],
          "assertions": [{ "path": "ok", "equals": true }]
        },
        {
          "command": ["scrape", "register-script", "--target-key", "strength-delta", "--script-file", "${TMP_ROOT}/scripts/delta.sh", "--language", "sh", "--runtime-root", "${TMP_ROOT}/rt"],
          "assertions": [{ "path": "ok", "equals": true }]
        },
        {
          "command": ["scrape", "execute", "--target-key", "strength-delta", "--runtime-root", "${TMP_ROOT}/rt", "--timeout-seconds", "30", "--input-json", "{\"phase\":1}"],
          "assertions": [
            { "path": "status", "equals": "succeeded" },
            { "path": "records_found", "equals": 3 },
            { "path": "materialization.inserted_count", "equals": 3 },
            { "path": "materialization.deleted_count", "equals": 0 }
          ]
        }
      ],
      "command": ["scrape", "execute", "--target-key", "strength-delta", "--runtime-root", "${TMP_ROOT}/rt", "--timeout-seconds", "30", "--input-json", "{\"phase\":2}"],
      "assertions": [
        { "path": "ok", "equals": true },
        { "path": "status", "equals": "succeeded" },
        { "path": "records_found", "equals": 3 },
        { "path": "materialization.inserted_count", "equals": 1 },
        { "path": "materialization.updated_count", "equals": 1 },
        { "path": "materialization.deleted_count", "equals": 1 },
        { "path": "materialization.unchanged_count", "equals": 1 }
      ]
    }
  ]
}
