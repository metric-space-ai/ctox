        {
          "path": "tool",
          "equals": "ctox_browser_prepare"
        },
        {
          "path": "install.ok",
          "equals": true
        },
        {
          "path": "install.package_json_created",
          "equals": true
        },
        {
          "path": "doctor.package_json_exists",
          "equals": true
        },
        {
          "path": "bootstrap.ok",
          "equals": true
        }
      ]
    }
  ]
}
