{
  "version": 1,
  "cases": [
    {
      "id": "live.web_search.rfc9110",
      "tier": "live",
      "tool": "ctox_web_search",
      "families": ["BrowseComp"],
      "setup": [
        {
          "write_text": {
            "path": "${TMP_ROOT}/runtime/ctox.sqlite3",
            "content": "CTOX_WEB_SEARCH_TIMEOUT_MS=20000\nCTOX_WEB_SEARCH_MAX_PAGE_BYTES=2000000\n"
          }
        }
      ],
      "command": [
        "web",
        "search",
        "--query",
        "RFC 9110 HTTP Semantics",
        "--domain",
        "rfc-editor.org",
        "--include-sources"
      ],
      "assertions": [
        {
          "path": "ok",
          "equals": true
        },
        {
          "path": "tool",
          "equals": "ctox_web_search"
        },
        {
          "path": "results",
          "len_gte": 1
        },
        {
          "path": "context",
          "contains": "HTTP"
        }
      ]
    },
    {
      "id": "live.web_read.rfc9110",
