    {
      "id": "live.browser_automation.local_click",
      "tier": "live",
      "tool": "ctox_browser_automation",
      "families": ["MiniWoB++", "Mind2Web"],
      "setup": [
        {
          "write_text": {
            "path": "${TMP_ROOT}/browser-script.js",
            "content": "await page.goto('${FIXTURE_BASE_URL}/browser.html', { waitUntil: 'domcontentloaded' });\nconst title = await page.title();\nawait page.click('#confirm');\nconst status = await page.textContent('#status');\nreturn { title, status };\n"
          }
        },
        {
          "command": [
            "web",
            "browser-prepare",
            "--dir",
            "${TMP_ROOT}/browser-reference",
            "--install-reference",
            "--install-browser"
          ],
          "assertions": [
            {
              "path": "ok",
              "equals": true
            },
            {
              "path": "doctor.automation_ready",
              "equals": true
            }
          ]
        }
      ],
      "command": [
        "web",
        "browser-automation",
        "--dir",
        "${TMP_ROOT}/browser-reference",
        "--timeout-ms",
        "120000",
        "--script-file",
        "${TMP_ROOT}/browser-script.js"
      ],
      "assertions": [
        {
          "path": "ok",
          "equals": true
        },
        {
          "path": "tool",
          "equals": "ctox_browser_automation"
        },
        {
          "path": "result.status",
          "equals": "clicked-ok"
        },
        {
          "path": "page.title",
          "equals": "CTOX Browser Bench"
        }
      ]
    }
  ]
}
