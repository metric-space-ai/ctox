{
  "schema_version": "ctox-office-oracle-flow-v1",
  "feature_id": "document.links-bookmarks-fields",
  "url": "http://127.0.0.1:4179/src/apps/business-os/office-engine/oracle/side-by-side.html?feature=document.links-bookmarks-fields",
  "playwright_flow": "oracle/flows/document.links-bookmarks-fields.playwright.js",
  "preconditions": [
    "Pinned Euro-Office v9.3.1 oracle is healthy on http://127.0.0.1:8088/healthcheck",
    "Repository static server is listening on port 4179",
    "Development-only callback server is listening on port 4180",
    "Browser viewport is 1600x900 CSS pixels",
    "The side-by-side gate accepts only exact document-ready, not app-ready",
    "CTOX uses output/playwright/ctox-office/rust/document.links-bookmarks-fields/ctox-rust.Editor.bin as the editor payload"
  ],
  "steps": [
    { "action": "reset", "url": "http://127.0.0.1:4180/reset/document.links-bookmarks-fields", "method": "POST" },
    { "action": "wait_for", "semantic": "status=document-ready and page count=1" },
    { "action": "dismiss_transient", "label": "Multipage view", "button": "OK" },
    { "action": "find", "text": "LINK_CREATE_TARGET", "shortcut": "Meta+F", "selection_after_escape": true },
    { "action": "open_dialog", "dialog": "Linkeinstellungen", "shortcut": "Meta+K" },
    { "action": "fill", "label": "Verknüpfen mit", "value": "https://ctox.dev/office-oracle" },
    { "action": "fill", "label": "Anzeigen", "value": "CTOX_EXTERNAL_LINK" },
    { "action": "confirm", "button": "OK" },
    { "action": "find", "text": "BOOKMARK_CREATE_TARGET", "shortcut": "Meta+F", "selection_after_escape": true },
    { "action": "click", "tab": "Einfügen", "control": "Lesezeichen" },
    { "action": "fill", "label": "Lesezeichenname", "value": "ctox_oracle_bookmark" },
    { "action": "click", "button": "Hinzufügen" },
    { "action": "find", "text": "99", "shortcut": "Meta+F", "selection_after_escape": true },
    { "action": "open_context_menu", "shortcut": "Shift+F10" },
    { "action": "click", "control": "Feld aktualisieren" },
    { "action": "assert_semantic", "values": { "external_link_text": "CTOX_EXTERNAL_LINK", "external_link_url": "https://ctox.dev/office-oracle", "bookmark": "ctox_oracle_bookmark", "field_instruction": "NUMPAGES", "field_result": "1" } },
    { "action": "assert_preserved", "values": ["CTOX_EXISTING_LINK", "ctox_existing_bookmark", "PRESERVE_LINKS_BOOKMARKS_FIELDS_UNRELATED_B73A"] },
    { "action": "click", "role": "button", "name": "Speichern" },
    { "action": "wait_for", "semantic": "callback status=6 and saved=true" }
  ]
}
