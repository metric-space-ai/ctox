{
  "schema_version": "ctox-office-oracle-flow-v1",
  "feature_id": "document.edit-save",
  "url": "http://127.0.0.1:4179/src/apps/business-os/office-engine/oracle/document-edit-save.html",
  "preconditions": [
    "Pinned Euro-Office v9.3.1 oracle is healthy on http://127.0.0.1:8088/healthcheck",
    "Repository static server is listening on port 4179",
    "Development-only callback server is listening on port 4180",
    "Browser viewport is 1200x759 CSS pixels at device scale factor 2"
  ],
  "steps": [
    { "action": "reset", "url": "http://127.0.0.1:4180/reset/document.edit-save", "method": "POST" },
    { "action": "wait_for", "semantic": "status=document-ready" },
    { "action": "click", "target": "paragraph containing CTOX_EDIT_TARGET_ALPHA", "coordinates_from": "measured editor page rectangle" },
    { "action": "press", "key": "End" },
    { "action": "press", "key": "Shift+Home", "effect": "select complete marker line" },
    { "action": "type", "value": "CTOX_EDIT_RESULT_BRAVO_42" },
    { "action": "assert_text", "value": "CTOX_EDIT_RESULT_BRAVO_42" },
    { "action": "assert_absent", "value": "CTOX_EDIT_TARGET_ALPHA" },
    { "action": "click", "role": "button", "name": "Speichern" },
    { "action": "wait_for", "semantic": "callback status=6 and saved=true" },
    { "action": "reopen", "url": "http://127.0.0.1:4179/src/apps/business-os/office-engine/oracle/document-edit-save-reopen.html" },
    { "action": "assert_text", "value": "CTOX_EDIT_RESULT_BRAVO_42" },
    { "action": "assert_text", "value": "PRESERVE_THIS_UNRELATED_PARAGRAPH_7B21" }
  ]
}
