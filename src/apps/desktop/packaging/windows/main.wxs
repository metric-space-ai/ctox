<?xml version="1.0" encoding="windows-1252"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product
        Id="*"
        Name="CTOX Desktop"
        UpgradeCode="B8F3E4A1-7C2D-4E5F-9A1B-3D6C8E2F7A4B"
        Manufacturer="metric-space.ai"
        Language="1033"
        Codepage="1252"
        Version="0.1.0">

        <Package
            Id="*"
            Keywords="Installer"
            Description="CTOX Desktop Installer"
            Manufacturer="metric-space.ai"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252" />

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit." />

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1" />
        <Property Id="DiskPrompt" Value="CTOX Desktop Installation" />

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder" Name="PFiles">
                <Directory Id="APPLICATIONFOLDER" Name="CTOX Desktop">
                    <Component Id="MainExecutable" Guid="*">
                        <File
                            Id="CtoxDesktopExe"
                            Name="ctox-desktop.exe"
                            Source="ctox-desktop.exe"
                            KeyPath="yes" />
                    </Component>
                </Directory>
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="CTOX Desktop" />
            </Directory>
        </Directory>

        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcut" Guid="*">
                <Shortcut
                    Id="ApplicationStartMenuShortcut"
                    Name="CTOX Desktop"
                    Description="CTOX Desktop Application"
                    Target="[#CtoxDesktopExe]"
                    WorkingDirectory="APPLICATIONFOLDER"
                    Icon="ProductIcon" />
                <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
                <RegistryValue
                    Root="HKCU"
                    Key="Software\MetricSpaceAI\CTOXDesktop"
                    Name="installed"
                    Type="integer"
                    Value="1"
                    KeyPath="yes" />
            </Component>
        </DirectoryRef>

        <Icon Id="ProductIcon" SourceFile="ctox-desktop.ico" />
        <Property Id="ARPPRODUCTICON" Value="ProductIcon" />

        <Feature Id="MainApplication" Title="CTOX Desktop" Level="1">
            <ComponentRef Id="MainExecutable" />
            <ComponentRef Id="ApplicationShortcut" />
        </Feature>

        <UIRef Id="WixUI_InstallDir" />
        <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />
    </Product>
</Wix>
