{
  "protocol": "ctox-rxdb-protocol-v1",
  "phase": "rxdb-protocol-handshake",
  "roles": {
    "browser": "browser",
    "native": "ctox_instance"
  },
  "requiredCapabilities": [
    "ctox-schema-hash-v1",
    "ctox-peer-session-v1",
    "ctox-checkpoint-epoch-v1"
  ],
  "browserCapabilities": [
    "ctox-rxdb-browser-v1",
    "ctox-file-chunks-v1",
    "ctox-schema-hash-v1",
    "ctox-peer-session-v1",
    "ctox-checkpoint-epoch-v1",
    "ctox-checkpoint-generation-v2",
    "ctox-app-runtime-v1",
    "ctox-rxdb-query-fetch-v1",
    "ctox-presence-v1",
    "ctox-command-lifecycle-v2"
  ],
  "nativeCapabilities": [
    "ctox-rxdb-native-v1",
    "ctox-file-chunks-v1",
    "ctox-replication-handshake-v1",
    "ctox-schema-hash-v1",
    "ctox-peer-session-v1",
    "ctox-checkpoint-epoch-v1",
    "ctox-checkpoint-generation-v2",
    "ctox-app-runtime-v1",
    "ctox-rxdb-query-fetch-v1",
    "ctox-presence-v1",
    "ctox-command-lifecycle-v2"
  ],
  "optionalCapabilities": {
    "queryFetch": "ctox-rxdb-query-fetch-v1",
    "presence": "ctox-presence-v1",
    "commandLifecycle": "ctox-command-lifecycle-v2",
    "checkpointGeneration": "ctox-checkpoint-generation-v2",
    "appRuntime": "ctox-app-runtime-v1"
  },
  "presenceRpc": {
    "update": "rxdb.presence.update",
    "streamId": "presence$",
    "ttlMs": 45000,
    "refreshMs": 20000,
    "maxEntriesPerPeer": 32
  },
  "queryRpc": {
    "fetch": "rxdb.query.fetch",
    "chunk": "rxdb.query.chunk",
    "error": "rxdb.query.error",
    "cancel": "rxdb.query.cancel",
    "maxDocumentsPerChunk": 200,
    "maxBytesPerChunk": 262144,
    "maxInFlightStreams": 8,
    "maxQueryRuntimeMs": 30000,
    "defaultWindowLimit": 200
  },
  "fileRpc": {
    "fetch": "rxdb.file.fetch",
    "chunk": "rxdb.file.chunk",
    "error": "rxdb.file.error",
    "cancel": "rxdb.file.cancel",
    "maxBytesPerChunk": 262144
  },
  "errorCodes": {
    "protocolMissing": "ctox_rxdb_protocol_missing",
    "protocolMismatch": "ctox_rxdb_protocol_mismatch",
    "capabilityMissing": "ctox_rxdb_capability_missing",
    "collectionMismatch": "ctox_rxdb_collection_mismatch",
    "schemaVersionMismatch": "ctox_rxdb_schema_version_mismatch",
    "schemaHashMismatch": "ctox_rxdb_schema_hash_mismatch"
  },
  "schemaHashSources": {
    "businessOsRegistry": "business-os-schema-hash-registry-v1",
    "canonicalJson": "canonical-json-schema-sha256-v1",
    "rxdbRs": "rxdb-rs-schema-hash-v1"
  },
  "compatible": {
    "browser": {
      "protocol": "ctox-rxdb-protocol-v1",
      "capabilities": [
        "ctox-checkpoint-epoch-v1",
        "ctox-file-chunks-v1",
        "ctox-peer-session-v1",
        "ctox-rxdb-browser-v1",
        "ctox-schema-hash-v1"
      ],
      "collection": {
        "name": "desktop_files",
        "schemaVersion": 1,
        "schemaHash": "fixture-schema-hash",
        "schemaHashSource": "rxdb-rs-schema-hash-v1",
        "checkpoint": {
          "state": "advertised",
          "epoch": "browser-epoch-1"
        }
      },
      "peerSession": {
        "role": "browser",
        "sessionId": "browser-fixture-session",
        "generation": 1
      }
    },
    "native": {
      "protocol": "ctox-rxdb-protocol-v1",
      "capabilities": [
        "ctox-checkpoint-epoch-v1",
        "ctox-file-chunks-v1",
        "ctox-peer-session-v1",
        "ctox-replication-handshake-v1",
        "ctox-rxdb-native-v1",
        "ctox-schema-hash-v1"
      ],
      "collection": {
        "name": "desktop_files",
        "schemaVersion": 1,
        "schemaHash": "fixture-schema-hash",
        "schemaHashSource": "business-os-schema-hash-registry-v1",
        "checkpoint": {
          "state": "advertised",
          "epoch": "native-epoch-1"
        }
      },
      "peerSession": {
        "role": "ctox_instance",
        "sessionId": "native-fixture-session"
      }
    }
  }
}
